# yamllint config — relaxed pour klodr/* (workflows GH Actions friendly)
extends: default

rules:
  line-length: disable
  document-start: disable
  truthy:
    allowed-values: ['true', 'false']
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  indentation:
    spaces: 2
    indent-sequences: consistent
  braces:
    max-spaces-inside: 1
  brackets:
    max-spaces-inside: 1

ignore: |
  node_modules/
  coverage/
  .husky/_/
  package-lock.json
