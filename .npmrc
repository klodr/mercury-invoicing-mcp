# Enforce engines.node locally: `npm install` on a Node older than the
# declared floor fails immediately instead of warning. Without this the
# engines field is metadata only.
#
# The floor (22.23.1) is the latest Node 22.x security release; older
# patch releases (22.0.0 → 22.23.0) miss at least one advisory fix and
# we want to refuse them outright rather than warn on.
engine-strict=true
