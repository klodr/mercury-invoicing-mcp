# Enforce engines.node locally: `npm install` on a Node older than the
# declared floor fails immediately instead of warning. Without this the
# engines field is metadata only.
#
# The floor (22.22.2) is the first Node 22 release without any known
# CVE; older patch releases (22.0.0 → 22.22.1) carry advisories we
# want to refuse outright rather than warn on.
engine-strict=true
